{
  "name": "@deepsweet/mdn",
  "version": "0.3.0",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "mdn": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist/"
  ],
  "dependencies": {
    "@huggingface/hub": "^2.11.0",
    "@lancedb/lancedb": "^0.27.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "apache-arrow": "18.1.0",
    "node-llama-cpp": "^3.18.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@deepsweet/eslint-config": "^0.1.0",
    "@types/bun": "^1.3.11",
    "dedent": "^1.7.2",
    "eslint": "^10.1.0",
    "gray-matter": "^4.0.3",
    "marked": "^17.0.5",
    "p-all": "^5.0.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2"
  },
  "scripts": {
    "download": "bun scripts/download.ts",
    "chunk": "bun scripts/chunk.ts",
    "ingest": "bun scripts/ingest.ts",
    "update": "bun scripts/update.ts",
    "query": "bun scripts/query.ts",
    "upload": "bun scripts/upload.ts",
    "test": "bun scripts/test.ts",
    "check": "tsc --noEmit && eslint --cache scripts/ src/",
    "dist": "bun build --format esm --target node --packages external --outdir dist/ src/index.ts"
  },
  "license": "MIT"
}
